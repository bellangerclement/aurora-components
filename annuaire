<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    .aurora-certified-directory {
      --ink: #10201c;
      --muted: #5c6f68;
      --line: #dce8e3;
      --soft: #f3faf7;
      --primary: #0f766e;
      --primary-soft: #e4f5f1;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: #f7fbf9;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 24px;
    }

    .aurora-directory-header {
      max-width: 760px;
      margin-bottom: 22px;
    }

    .aurora-directory-kicker {
      margin: 0 0 8px;
      color: var(--primary);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .aurora-directory-header h2 {
      margin: 0;
      color: var(--ink);
      font-size: clamp(26px, 3vw, 38px);
      line-height: 1.08;
    }

    .aurora-directory-header p {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
    }

    .aurora-directory-status,
    .aurora-directory-card {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fff;
    }

    .aurora-directory-status {
      padding: 18px;
      color: var(--muted);
      font-size: 14px;
    }

    .aurora-directory-grid {
      display: grid;
      gap: 14px;
    }

    .aurora-directory-card {
      padding: 18px;
      box-shadow: 0 10px 24px rgba(15, 118, 110, 0.06);
    }

    .aurora-directory-card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }

    .aurora-directory-card h3 {
      margin: 0;
      color: var(--ink);
      font-size: 18px;
      line-height: 1.25;
    }

    .aurora-directory-card p {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .aurora-directory-badge {
      border: 1px solid #b7ead8;
      border-radius: 999px;
      background: #ebfbf4;
      padding: 6px 10px;
      color: #047857;
      font-size: 12px;
      font-weight: 800;
      white-space: nowrap;
    }

    .aurora-directory-details {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-top: 18px;
    }

    .aurora-directory-details span {
      display: block;
      margin-bottom: 8px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .aurora-directory-details strong {
      display: block;
      color: var(--ink);
      font-size: 14px;
    }

    .aurora-directory-chips {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .aurora-directory-chip {
      width: fit-content;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: var(--soft);
      padding: 6px 8px;
      color: var(--ink);
      font-size: 12px;
      font-weight: 700;
    }

    .aurora-directory-link {
      display: inline-flex;
      align-items: center;
      margin-top: 12px;
      border: 1px solid #99d7ce;
      border-radius: 6px;
      background: var(--primary-soft);
      padding: 9px 12px;
      color: #064e3b;
      font-size: 13px;
      font-weight: 800;
      text-decoration: none;
    }

    .aurora-directory-link:hover {
      border-color: var(--primary);
      background: #d7f0eb;
    }

    .aurora-directory-muted {
      color: var(--muted);
      font-size: 13px;
    }

    .aurora-directory-scope {
      margin-top: 16px;
      border-radius: 6px;
      background: var(--soft);
      padding: 12px;
    }

    @media (max-width: 760px) {
      .aurora-certified-directory {
        padding: 18px;
      }

      .aurora-directory-card-top,
      .aurora-directory-details {
        display: grid;
        grid-template-columns: 1fr;
      }

      .aurora-directory-badge {
        width: fit-content;
      }
    }
  </style>
</head>

<body>
  <section
    class="aurora-certified-directory"
    data-api-url="https://api.aurora-cabinet.app/public/certificates"
  >
    <div class="aurora-directory-header">
      <p class="aurora-directory-kicker">Annuaire public</p>
      <h2>Organismes certifiés PSDM</h2>
      <p>
        Liste dynamique des certificats PSDM délivrés par Aurora Cabinet, avec
        dates de certification, surveillances et accès au certificat Drive.
      </p>
    </div>

    <div class="aurora-directory-status" data-directory-status>
      Chargement de l'annuaire...
    </div>

    <div class="aurora-directory-grid" data-directory-list></div>
  </section>

  <script>
    (function () {
      const root = document.querySelector(".aurora-certified-directory");
      if (!root) return;

      const apiUrl = root.dataset.apiUrl;
      const statusNode = root.querySelector("[data-directory-status]");
      const listNode = root.querySelector("[data-directory-list]");

      const statusLabels = {
        ACTIVE: "Actif",
        EXPIRED: "Expiré",
        SUSPENDED: "Suspendu",
        WITHDRAWN: "Retiré",
      };

      const surveillanceLabels = {
        PLANNED: "Planifiée",
        DUE: "À réaliser",
        OVERDUE: "En retard",
        COMPLETED: "Réalisée",
        CANCELLED: "Annulée",
      };

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function formatDate(value) {
        if (!value) return "-";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "-";

        return new Intl.DateTimeFormat("fr-FR", {
          day: "2-digit",
          month: "2-digit",
          year: "numeric",
        }).format(date);
      }

      function formatSurveillance(plan) {
        const label = surveillanceLabels[plan.status] || plan.status || "-";
        const date = plan.completedAt
          ? formatDate(plan.completedAt)
          : formatDate(plan.dueAt);

        return `${label} · ${date}`;
      }

      function renderCertificate(certificate) {
        const client = certificate.client || {};
        const surveillances = Array.isArray(certificate.surveillancePlans)
          ? certificate.surveillancePlans
          : [];
        const sites = Array.isArray(certificate.sites) ? certificate.sites : [];

        const siteLabel =
          sites.length > 0
            ? sites
                .map((site) =>
                  [site.name, [site.postalCode, site.city].filter(Boolean).join(" ")]
                    .filter(Boolean)
                    .join(" - ")
                )
                .join(", ")
            : "-";

        const surveillanceHtml =
          surveillances.length > 0
            ? surveillances
                .map(
                  (plan) =>
                    `<span class="aurora-directory-chip">${escapeHtml(
                      formatSurveillance(plan)
                    )}</span>`
                )
                .join("")
            : '<span class="aurora-directory-muted">Aucune surveillance publiée</span>';

        const certificateLink = certificate.pdfPath
          ? `<a class="aurora-directory-link" href="${escapeHtml(
              certificate.pdfPath
            )}" target="_blank" rel="noopener noreferrer">Voir le certificat</a>`
          : '<span class="aurora-directory-muted">Certificat non rattaché</span>';

        return `
          <article class="aurora-directory-card">
            <div class="aurora-directory-card-top">
              <div>
                <h3>${escapeHtml(client.companyName || "Organisme")}</h3>
                <p>${client.siret ? `SIRET ${escapeHtml(client.siret)}` : "SIRET non publié"}</p>
              </div>

              <span class="aurora-directory-badge">
                ${escapeHtml(statusLabels[certificate.status] || certificate.status || "-")}
              </span>
            </div>

            <div class="aurora-directory-details">
              <div>
                <span>Certificat</span>
                <strong>${escapeHtml(certificate.certificateNumber || "-")}</strong>
                <p>Certifié le ${formatDate(certificate.issuedAt)}</p>
                <p>Valide jusqu'au ${formatDate(certificate.expiresAt)}</p>
              </div>

              <div>
                <span>Surveillances</span>
                <div class="aurora-directory-chips">${surveillanceHtml}</div>
              </div>

              <div>
                <span>Sites</span>
                <p>${escapeHtml(siteLabel)}</p>
                ${certificateLink}
              </div>
            </div>

            ${
              certificate.scope
                ? `<p class="aurora-directory-scope">${escapeHtml(certificate.scope)}</p>`
                : ""
            }
          </article>
        `;
      }

      async function loadDirectory() {
        try {
          const response = await fetch(apiUrl, { cache: "no-store" });
          if (!response.ok) throw new Error("HTTP " + response.status);

          const payload = await response.json();
          const certificates = Array.isArray(payload.data) ? payload.data : [];

          if (certificates.length === 0) {
            statusNode.textContent = "Aucun certificat publié.";
            return;
          }

          statusNode.remove();
          listNode.innerHTML = certificates.map(renderCertificate).join("");
        } catch (error) {
          statusNode.textContent =
            "Annuaire indisponible. Vérifier l'URL API et les autorisations CORS.";
        }
      }

      loadDirectory();
    })();
  </script>
</body>
</html>
